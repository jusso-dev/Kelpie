# Database
DATABASE_URL=postgres://kelpie:kelpie@localhost:5432/kelpie

# BetterAuth
BETTER_AUTH_SECRET=replace_me_with_a_long_random_secret
BETTER_AUTH_URL=http://localhost:3000

# App
APP_URL=http://localhost:3000
NODE_ENV=development

# Email (optional, falls back to console in dev)
EMAIL_FROM=kelpie@example.com
RESEND_API_KEY=

# Shared secret for /api/cron/* endpoints. Required for the SLA, webhook,
# enrichment, SIEM connector, and threat-intel runners. Set to a long random
# string.
CRON_SECRET=replace_me_with_a_long_random_cron_secret

# Single sign-on (SAML / OIDC) and SOAR action callback URLs are built from
# APP_URL (above). Set APP_URL to your public origin so IdP redirect/ACS URLs
# and the per-org SSO endpoints resolve correctly. SSO providers, SIEM
# connectors, TI feeds, and response actions are all configured per
# organisation from the UI; no extra env is required for them.

# Optional: org-level VirusTotal key can be set under Settings; this env is
# used as a fallback for single-tenant installs.
VIRUSTOTAL_API_KEY=

# File storage. Local disk by default. Set S3 vars to use S3 or MinIO.
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads

# Set only when Kelpie must call intentionally private, self-hosted integrations.
KELPIE_ALLOW_PRIVATE_NETWORKS=false
S3_BUCKET=
S3_REGION=ap-southeast-2
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
