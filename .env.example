# Database
DATABASE_URL=postgres://kelpie:kelpie@localhost:5432/kelpie

# BetterAuth
BETTER_AUTH_SECRET=replace_me_with_a_long_random_secret
BETTER_AUTH_URL=http://localhost:3000

# App
APP_URL=http://localhost:3000
NODE_ENV=development

# Email (optional, falls back to console in dev)
EMAIL_FROM=kelpie@example.com
RESEND_API_KEY=

# Shared secret for /api/cron/* endpoints. Required for SLA, webhook, and
# enrichment runners. Set to a long random string.
CRON_SECRET=replace_me_with_a_long_random_cron_secret

# Optional: org-level VirusTotal key can be set under Settings; this env is
# used as a fallback for single-tenant installs.
VIRUSTOTAL_API_KEY=

# File storage. Local disk by default. Set S3 vars to use S3 or MinIO.
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads
S3_BUCKET=
S3_REGION=ap-southeast-2
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
